# 数据库连接字符串 (生产环境)
# 格式：Server=<服务器地址>;Database=<数据库名>;User Id=<用户名>;Password=<密码>
ConnectionStrings__DefaultConnection=Server=localhost;Database=EnglishLearning;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=True;

# JWT 密钥配置 (生产环境必须使用强密钥)
# 密钥必须至少 32 个字符
JwtSettings__SecretKey=YourSuperSecretProductionKeyThatIsAtLeast32CharactersLong!
JwtSettings__Issuer=EnglishLearning
JwtSettings__Audience=EnglishLearning
JwtSettings__ExpirationMinutes=120
